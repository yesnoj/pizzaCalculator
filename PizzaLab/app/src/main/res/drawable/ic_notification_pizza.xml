<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">
    <!--
      Pizza slice icon — tilted ~30°, with crust arc and round toppings.
      Style matches reference: filled slice body, crust band at the top-right arc,
      three round cutouts for toppings.
    -->

    <!-- Slice body (tilted triangle with arc top = crust) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M3.5,21.5 L9.2,3.8 A10,10 0,0 1,20.2,9.2 Z" />

    <!-- Crust arc band (slightly smaller arc to create the crust strip) -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="0.5"
        android:pathData="M10.2,5.5 A8,8 0,0 1,18.8,10.2" />

    <!-- Inner line separating crust from cheese -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#00000000"
        android:pathData="M10.6,6.2 A7,7 0,0 1,18,10.8" />

    <!-- Crust cutout: creates a visible gap between crust and cheese -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="@android:color/transparent"
        android:strokeWidth="1.2"
        android:pathData="M10.0,5.2 A8.5,8.5 0,0 1,19.0,9.8" />

    <!-- Topping 1 (top-right area) -->
    <path
        android:fillColor="#00000000"
        android:pathData="M14.5,8.5 m-1.3,0 a1.3,1.3 0,1 1,2.6 0 a1.3,1.3 0,1 1,-2.6 0" />

    <!-- Topping 2 (middle) -->
    <path
        android:fillColor="#00000000"
        android:pathData="M10.5,11.5 m-1.3,0 a1.3,1.3 0,1 1,2.6 0 a1.3,1.3 0,1 1,-2.6 0" />

    <!-- Topping 3 (bottom-left, near tip) -->
    <path
        android:fillColor="#00000000"
        android:pathData="M7.0,16.0 m-1.1,0 a1.1,1.1 0,1 1,2.2 0 a1.1,1.1 0,1 1,-2.2 0" />
</vector>
